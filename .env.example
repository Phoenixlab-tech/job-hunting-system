# Claude API (pour Netlify Functions)
# Obtenir sur : https://console.anthropic.com/
# Copier la clé sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...

# API France Travail
# Credentials à obtenir sur https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=votre_client_id_ici
FRANCE_TRAVAIL_CLIENT_SECRET=votre_client_secret_ici

# Google Sheets
# Credentials service account (gépérez .json dans mcp-config/)
GOOGLE_SHEETS_CREDENTIALS=mcp-config/google-sheets-credentials.json
